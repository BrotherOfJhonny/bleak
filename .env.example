# BLEAK Environment Configuration
# Copy this file to .env and fill in your values
# NEVER commit .env to version control

# Optional: Override Mi Band default auth key (hex, 32 chars)
# MIBAND_AUTH_KEY=30313233343536373839404142434445

# Optional: Flask secret key (generated automatically if not set)
# BLEAK_SECRET_KEY=your-random-secret-here

# Optional: Bind host/port
# BLEAK_HOST=0.0.0.0
# BLEAK_PORT=8080

# Optional: Tool paths (auto-detected if in tools/ subdir)
# APPLEJUICE_PATH=/opt/AppleJuice/app.py
# BLUEDUCKY_PATH=/opt/BlueDucky/BlueDucky.py
